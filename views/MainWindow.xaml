<Window x:Class="ProcessManagerUltimate.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:lvc="clr-namespace:LiveCharts.Wpf;assembly=LiveCharts.Wpf"
        xmlns:conv="clr-namespace:ProcessManagerUltimate.Converters"
        Title="Process Manager Ultimate" 
        Height="950" 
        Width="1500"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <conv:BytesToMBConverter x:Key="BytesToMBConverter"/>
        <conv:PriorityToBrushConverter x:Key="PriorityToBrushConverter"/>
        <conv:PriorityToRussianConverter x:Key="PriorityToRussianConverter"/>
        <conv:CoreRangeConverter x:Key="CoreRangeConverter"/>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="3*"/>
            <ColumnDefinition Width="1.5*"/>
        </Grid.ColumnDefinitions>

        <TabControl Grid.Column="0">
            <TabItem Header="Процессы">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Панель инструментов -->
                    <Border Grid.Row="0" Background="#F0F0F0" Padding="5" Margin="0,0,0,5" CornerRadius="3">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="Выделено процессов: " VerticalAlignment="Center" Margin="5,0"/>
                            <TextBlock Text="{Binding SelectedProcessesCount}" FontWeight="Bold" VerticalAlignment="Center" Margin="0,0,10,0"/>

                            <Button Content="Выделить всё" Click="SelectAll_Click" Margin="5,0" Padding="10,3"/>
                            <Button Content="Снять выделение" Click="DeselectAll_Click" Margin="5,0" Padding="10,3"/>
                            <Button Content="Сбросить выбор строки" Click="ClearSelection_Click" Margin="5,0" Padding="10,3"/>

                            <Separator Width="2" Background="#CCC" Margin="10,0"/>

                            <TextBlock Text="Приоритет для выделенных: " VerticalAlignment="Center" Margin="5,0"/>
                            <ComboBox x:Name="BulkPriorityCombo" 
                                      ItemsSource="{Binding RussianPriorityClasses}" 
                                      DisplayMemberPath="Name"
                                      SelectedValuePath="Value"
                                      Width="120" Margin="5,0"/>
                            <Button Content="Применить" Click="ApplyPriorityToSelected_Click" Margin="5,0" Padding="10,3"/>

                            <Separator Width="2" Background="#CCC" Margin="10,0"/>

                            <TextBlock Text="Ядра для выделенных: " VerticalAlignment="Center" Margin="5,0"/>
                            <TextBox x:Name="BulkAffinityTextBox" Width="100" Margin="5,0" Padding="3" 
                                     ToolTip="Введите номера ядер через запятую, например: 0,2,4"/>
                            <Button Content="Применить" Click="ApplyAffinityToSelected_Click" Margin="5,0" Padding="10,3"/>
                        </StackPanel>
                    </Border>

                    <!-- Таблица процессов -->
                    <DataGrid Grid.Row="1"
                              ItemsSource="{Binding Processes}"
                              SelectedItem="{Binding SelectedProcess, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                              AutoGenerateColumns="False"
                              IsReadOnly="False"
                              CanUserSortColumns="True"
                              CanUserResizeColumns="True"
                              GridLinesVisibility="All"
                              RowDetailsVisibilityMode="VisibleWhenSelected"
                              SelectionMode="Single"
                              SelectionUnit="FullRow">
                        <DataGrid.Columns>
                            <!-- Галочка выделения -->
                            <DataGridCheckBoxColumn Header="✓" 
                                                    Binding="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                                                    Width="40"
                                                    CanUserSort="False"
                                                    CanUserResize="False">
                                <DataGridCheckBoxColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="HorizontalAlignment" Value="Center"/>
                                        <Setter Property="VerticalAlignment" Value="Center"/>
                                    </Style>
                                </DataGridCheckBoxColumn.CellStyle>
                            </DataGridCheckBoxColumn>

                            <DataGridTextColumn Header="PID" Binding="{Binding Id}" IsReadOnly="True" Width="80"/>
                            <DataGridTextColumn Header="Имя" Binding="{Binding Name}" IsReadOnly="True" Width="200"/>

                            <!-- Приоритет с русским названием -->
                            <DataGridTextColumn Header="Приоритет" 
                                                Binding="{Binding Priority, Converter={StaticResource PriorityToRussianConverter}}" 
                                                IsReadOnly="True" 
                                                Width="140">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="Background" 
                                                Value="{Binding Priority, Converter={StaticResource PriorityToBrushConverter}}"/>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Память (МБ)" 
                                                Binding="{Binding MemoryUsage, Converter={StaticResource BytesToMBConverter}}" 
                                                IsReadOnly="True" 
                                                Width="110"/>

                            <!-- Привязка ядер с динамическим заголовком -->
                            <DataGridTextColumn Header="{Binding CoreCount, Converter={StaticResource CoreRangeConverter}}" 
                                                Binding="{Binding AffinityString, UpdateSourceTrigger=LostFocus, Mode=TwoWay}" 
                                                Width="120">
                                <DataGridTextColumn.CellStyle>
                                    <Style TargetType="DataGridCell">
                                        <Setter Property="ToolTip" Value="Введите номера ядер через запятую, например: 0,2,4"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsSelected" Value="True">
                                                <Setter Property="Background" Value="#FFE6F7FF"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </DataGridTextColumn.CellStyle>
                            </DataGridTextColumn>

                            <DataGridTextColumn Header="Потоки" Binding="{Binding ThreadCount}" IsReadOnly="True" Width="70"/>
                            <DataGridTextColumn Header="Время CPU" Binding="{Binding CpuTime}" IsReadOnly="True" Width="100"/>
                            <DataGridCheckBoxColumn Header="Отвечает" Binding="{Binding Responding}" IsReadOnly="True" Width="80"/>
                        </DataGrid.Columns>

                        <DataGrid.RowDetailsTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="10">
                                    <TextBlock Text="Выбран процесс: " FontWeight="Bold"/>
                                    <TextBlock Text="{Binding Name}" Margin="5,0"/>
                                    <TextBlock Text="PID: " FontWeight="Bold" Margin="20,0,0,0"/>
                                    <TextBlock Text="{Binding Id}" Margin="5,0"/>
                                </StackPanel>
                            </DataTemplate>
                        </DataGrid.RowDetailsTemplate>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="Дерево процессов">
                <TreeView ItemsSource="{Binding ProcessTree}" Margin="5">
                    <TreeView.ItemTemplate>
                        <HierarchicalDataTemplate ItemsSource="{Binding Children}">
                            <TextBlock Text="{Binding Process.Name}" FontSize="14" Margin="3"/>
                        </HierarchicalDataTemplate>
                    </TreeView.ItemTemplate>
                </TreeView>
            </TabItem>

            <TabItem Header="Потоки">
                <DataGrid ItemsSource="{Binding Threads}" AutoGenerateColumns="True" IsReadOnly="True" Margin="5"/>
            </TabItem>
        </TabControl>

        <!-- Правая панель -->
        <StackPanel Grid.Column="1" Margin="15,0,0,0">
            <TextBlock Text="Использование CPU (%)" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
            <lvc:CartesianChart Series="{Binding CpuSeries}" Height="250" Margin="0,0,0,20"/>

            <Border BorderBrush="#CCC" BorderThickness="1" CornerRadius="5" Padding="10" Margin="0,0,0,20">
                <StackPanel>
                    <TextBlock Text="Выбранный процесс" FontWeight="Bold" FontSize="14" Margin="0,0,0,5"/>
                    <TextBlock Text="{Binding SelectedProcess.Name, StringFormat='Имя: {0}'}" Margin="0,2"/>
                    <TextBlock Text="{Binding SelectedProcess.Id, StringFormat='PID: {0}'}" Margin="0,2"/>
                    <TextBlock Text="{Binding SelectedProcess.Priority, Converter={StaticResource PriorityToRussianConverter}, StringFormat='Приоритет: {0}'}" Margin="0,2"/>
                </StackPanel>
            </Border>

            <TextBlock Text="Топ-10 по потреблению памяти" FontWeight="Bold" FontSize="16" Margin="0,0,0,10"/>
            <ListView ItemsSource="{Binding TopMemory}" Height="250">
                <ListView.View>
                    <GridView>
                        <GridViewColumn Header="Имя" DisplayMemberBinding="{Binding Name}" Width="180"/>
                        <GridViewColumn Header="Память (МБ)" DisplayMemberBinding="{Binding MemoryUsage, Converter={StaticResource BytesToMBConverter}}" Width="120"/>
                    </GridView>
                </ListView.View>
            </ListView>
        </StackPanel>
    </Grid>
</Window>